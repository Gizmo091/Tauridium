{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pakeFerdium",
  "version": "0.1.0",
  "identifier": "com.yobinext.pakeferdium",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "pakeFerdium",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
